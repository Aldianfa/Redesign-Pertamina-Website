{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    },
    {
        "src":"/assets/(.*)",
        "dest":"/public/assets/"
    },
    {
        "src":"/storage/(.*)",
        "dest":"/public/storage/"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "LOG_CHANNEL": "stderr"
  }
}